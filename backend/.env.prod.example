ENVIRONMENT=prod

APP_NAME=Actora
SECRET_KEY=CHANGE_ME_IN_PROD
ROOT_PATH=

# 프론트엔드 origin (도커 내부 통신은 동일 origin이지만, 직접 CORS 호출 시 필요)
ALLOWED_DOMAINS=http://3.35.101.121,http://localhost

# PostgreSQL — 호스트 native 에 host.docker.internal 로 접근
# sync(psycopg2) URL — 런타임에서 async(asyncpg)로 자동 변환됨
DATABASE_URL=postgresql+psycopg2://actora_user:CHANGE_ME_PROD_PASSWORD@host.docker.internal:5432/actora

# Qdrant (docker network 내부)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Redis (현재 미사용. 사용 시 service 추가)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SESSION_TIMEOUT=3600

LOGGING_LEVEL=INFO
